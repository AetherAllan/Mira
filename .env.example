# OpenRouter Chat Completions endpoint.
BASE_URL=https://openrouter.ai/api/v1
API_KEY=
MODEL=openai/gpt-4.1-mini

# Public Beijing providers: Open-Meteo, Nominatim, OSRM and GDELT. Set this to
# false as an operational kill switch; provider failures never block world tick.
EXTERNAL_INGESTION_ENABLED=true

# Postgres (Neon or Railway pgvector template). App uses postgres.js over TCP.
DATABASE_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_WEBHOOK_SECRET=
CRON_SECRET=
ADMIN_PASSWORD=
