# OpenRouter Chat Completions endpoint.
BASE_URL=https://openrouter.ai/api/v1
API_KEY=
MODEL=openai/gpt-4.1-mini

# Beijing provider adapters. External ingestion remains disabled until QWeather
# is configured or EXTERNAL_INGESTION_ENABLED is explicitly enabled.
AMAP_WEB_API_KEY=
QWEATHER_API_KEY=
QWEATHER_API_HOST=
EXTERNAL_INGESTION_ENABLED=false

# Postgres (Neon or Railway pgvector template). App uses postgres.js over TCP.
DATABASE_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_WEBHOOK_SECRET=
CRON_SECRET=
ADMIN_PASSWORD=
