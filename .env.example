# OpenRouter Chat Completions endpoint.
BASE_URL=https://openrouter.ai/api/v1
API_KEY=
MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_WEB_SEARCH_ENABLED=false

# Public Beijing providers: Open-Meteo, Nominatim, OSRM and GDELT. Keep disabled
# for deterministic local/test ticks; production can opt in explicitly.
EXTERNAL_INGESTION_ENABLED=false

# Postgres (Neon or Railway pgvector template). App uses postgres.js over TCP.
DATABASE_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_WEBHOOK_SECRET=
CRON_SECRET=
ADMIN_PASSWORD=
